DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tokenix
JWT_SECRET=replace-with-a-long-random-secret
RPC_URL=http://localhost:8545
CONTRACT_ADDRESS=replace-with-synced-token-address
FAUCET_CONTRACT_ADDRESS=replace-with-synced-faucet-address
PORT=3000

# Wallet funding worker is opt-in. Do not enable it together with legacy funding.
WALLET_FUNDING_WORKER_ENABLED=false
WALLET_FUNDING_WORKER_ID=local-worker-1
WALLET_FUNDING_WORKER_POLL_MS=5000
WALLET_FUNDING_LEASE_SECONDS=30
WALLET_GAS_FUNDING_AMOUNT_ETH=0.005
WALLET_TOKEN_FUNDING_AMOUNT=100
TX_CONFIRMATIONS_REQUIRED=1

# Chain epoch protects local Hardhat resets. Use a new value after each fresh
# local deployment. Never rebroadcast signed transactions from an old epoch.
CHAIN_EPOCH_ID=replace-with-local-deployment-epoch

# Funding signer used only by the worker. Placeholder only; never commit a real key.
FAUCET_SIGNER_PRIVATE_KEY=replace-with-local-faucet-signer-private-key

# AES-256-GCM keyring for encrypted signed transaction outbox records.
# Values are base64-encoded 32-byte keys. Placeholder only.
TX_OUTBOX_ACTIVE_KEY_ID=local-key-1
TX_OUTBOX_ENCRYPTION_KEYS={"local-key-1":"replace-with-base64-32-byte-key"}
